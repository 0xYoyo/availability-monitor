    "kind": "telegram",
    "botTokenEnv": "TELEGRAM_BOT_TOKEN",
    "chatIdEnv": "TELEGRAM_CHAT_ID",
    "messagePrefix": "Metzoke Availability",
    "silent": false
  },
  "monitor": {
    "dateRangeStart": "tomorrow",
    "dateRangeEnd": "2026-04-13",
    "nightCount": 2,
    "guestCount": 2,
    "pollIntervalMinutes": 10,
    "cooldownMinutes": 60,
    "rooms": [
      {
        "id": "reservationtp",
