        "name": "Tenti N",
        "bookingUrl": "https://www.metzoke.co.il/reservationtN",
        "priority": 2
      },
      {
        "id": "reservationtmul",
        "name": "Mul Yam",
        "bookingUrl": "https://www.metzoke.co.il/reservationtMUL",
        "priority": 3
      },
      {
        "id": "reservationmy",
        "name": "My Room",
        "bookingUrl": "https://www.metzoke.co.il/reservationmy",
        "priority": 4
      },
      {
        "id": "reservationts",
